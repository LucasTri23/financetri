rules_version = '2';
// Regras de segurança do Firestore para o Controle Financeiro.
// Cole este conteúdo em: console do Firebase → Firestore Database → Regras → Publicar.
//
// - Cada usuário só pode ler/escrever os próprios dados, guardados em
//   usuarios/{uid}/dividas|saidas|entradas.
// - Planos compartilhados (planos/{planoId}) só podem ser lidos/alterados por
//   quem já é integrante; uma pessoa de fora pode entrar usando o código de
//   convite, desde que apenas adicione a si mesma à lista de membros.
// - Como o Firestore não permite consultas (queries) em coleções que o
//   solicitante não pode ler por inteiro, o código de convite não é buscado
//   com uma query em "planos" — em vez disso existe uma coleção auxiliar
//   "convites/{codigo}" (id = código), que mapeia o código para o id do
//   plano. Qualquer pessoa autenticada pode buscar um convite pelo código
//   exato (leitura direta por id, não uma lista), expondo só o id do plano.
service cloud.firestore {
  match /databases/{database}/documents {
    match /usuarios/{uid}/{documento=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /planos/{planoId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.membros;

      allow create: if request.auth != null
        && request.resource.data.donoId == request.auth.uid
        && request.resource.data.membros == [request.auth.uid];

      allow update: if request.auth != null && (
        // Integrantes atuais podem alterar os dados do plano.
        request.auth.uid in resource.data.membros
        ||
        // Alguém de fora pode entrar com o código de convite, desde que
        // esteja apenas adicionando a si mesmo à lista de membros.
        (request.resource.data.codigoConvite == resource.data.codigoConvite
          && request.resource.data.membros.size() == resource.data.membros.size() + 1
          && request.resource.data.membros.hasAll(resource.data.membros)
          && request.auth.uid in request.resource.data.membros)
      );

      allow delete: if request.auth != null && request.auth.uid == resource.data.donoId;
    }

    match /convites/{codigo} {
      // Buscar um convite exige saber o código exato (id do documento) —
      // não é uma lista, então não há risco de enumerar todos os planos.
      allow get: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.donoId == request.auth.uid;

      allow delete: if request.auth != null
        && request.auth.uid == resource.data.donoId;
    }
  }
}
