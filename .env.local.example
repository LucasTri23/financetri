# Copie este arquivo para .env.local e preencha com os valores reais.
# .env.local nunca é commitado (veja .gitignore).

# String de conexão do banco Postgres (Neon / Vercel Postgres).
# Painel da Vercel: Storage -> criar banco Postgres -> copiar a "DATABASE_URL".
DATABASE_URL="postgresql://usuario:senha@host/banco?sslmode=require"

# Segredo usado pelo NextAuth para assinar sessões/tokens.
# Gere um valor aleatório com: npx auth secret
AUTH_SECRET=""

# Credenciais OAuth do Google (console.cloud.google.com -> APIs e serviços
# -> Credenciais -> criar "ID do cliente OAuth" do tipo "Aplicativo da Web").
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
