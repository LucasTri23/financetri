# Copie este arquivo para .env.local e preencha com os valores reais.
# .env.local nunca é commitado (veja .gitignore).

# String de conexão do banco Postgres (Neon / Vercel Postgres).
# Painel da Vercel: Storage -> seu banco -> aba ".env.local" -> copiar DATABASE_URL
DATABASE_URL=""

# Versão sem pooler — usada pelas migrations do Drizzle.
# Igual ao DATABASE_URL mas sem "-pooler" no hostname.
DATABASE_URL_UNPOOLED=""

# Segredo usado pelo NextAuth para assinar sessões/tokens.
# Gere com: npx auth secret
AUTH_SECRET=""

# Credenciais OAuth do Google (console.cloud.google.com)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
